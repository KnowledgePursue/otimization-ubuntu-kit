# =========================
# SERVER CONFIGURATION
# =========================

DOMAIN="example.com"
EMAIL="admin@example.com"

# Recursos do servidor
SWAP_SIZE="2G"

# Versões
PHP_VERSION="8.3"

# Serviços
INSTALL_WORDPRESS="true"
INSTALL_MARIADB="true"
INSTALL_REDIS="true"

# Segurança
ENABLE_UFW="true"
ENABLE_FAIL2BAN="true"

# Logs
LOG_FILE="/var/log/server-setup.log"